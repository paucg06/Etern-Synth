<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EternSynth.MainWindow"
        Title="EternSynth // Generador de Sonidos Retro"
        Width="1120" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid RowDefinitions="Auto,*">
        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#181818" Foreground="White">
            <MenuItem Header="_Archivo">
                <MenuItem Header="📁 Cargar parámetros desde disco..." Click="LoadParams_Click" />
                <MenuItem Header="💿 Guardar parámetros en disco..." Click="SaveParams_Click" />
                <MenuItem Header="💾 Exportar archivo .WAV..." Click="ExportWav_Click" />
                <Separator/>
                <MenuItem Header="❌ Salir" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Editar">
                <MenuItem Header="📋 Copiar parámetros" Click="CopyParams_Click" />
                <MenuItem Header="📥 Pegar parámetros" Click="PasteParams_Click" />
                <Separator/>
                <MenuItem Header="🧪 Mutar copia de sonido activo" Click="Mutate_Click" />
                <MenuItem Header="🎲 Generar sonido aleatorio" Click="Random_Click" />
            </MenuItem>
            <MenuItem Header="_Ver">
                <MenuItem Header="👁️ Alternar Barra Lateral de Sonidos" Click="ToggleSidebar_Click" />
                <Separator/>
                <MenuItem Header="🔳 Forma de Onda: Cuadrada" Click="WaveCuadrada_Click" />
                <MenuItem Header="📈 Forma de Onda: Sierra" Click="WaveSierra_Click" />
                <MenuItem Header="〰️ Forma de Onda: Senoidal" Click="WaveSenoidal_Click" />
                <MenuItem Header="💨 Forma de Onda: Ruido" Click="WaveRuido_Click" />
                <MenuItem Header="🔺 Forma de Onda: Triangular" Click="WaveTriangular_Click" />
            </MenuItem>
            <MenuItem Header="_Herramientas">
                <MenuItem Header="🪙 Preajuste: Moneda" Click="PresetCoin_Click" />
                <MenuItem Header="🔫 Preajuste: Disparo / Láser" Click="PresetLaser_Click" />
                <MenuItem Header="💥 Preajuste: Explosión" Click="PresetExplosion_Click" />
                <MenuItem Header="⚡ Preajuste: Powerup" Click="PresetPowerup_Click" />
                <MenuItem Header="🤕 Preajuste: Daño / Golpe" Click="PresetHitHurt_Click" />
                <MenuItem Header="🦘 Preajuste: Salto" Click="PresetJump_Click" />
                <MenuItem Header="👾 Preajuste: Blip" Click="PresetBlip_Click" />
                <Separator/>
                <MenuItem Header="🔄 Restablecer parámetros" Click="ResetParams_Click" />
            </MenuItem>
            <MenuItem Header="A_yuda">
                <MenuItem Header="ℹ️ Acerca de EternSynth" Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- Main Workspace -->
        <Grid Grid.Row="1" Name="ContentGrid" ColumnDefinitions="240,4,*">
            <!-- Sidebar (Column 0) -->
            <Border Grid.Column="0" Name="SidebarBorder" Background="#1a1a1a" BorderBrush="#2d2d2d" BorderThickness="0,0,1,0" Padding="12">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Sidebar Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0" Text="SONIDOS GUARDADOS" FontSize="11" FontWeight="Bold" Foreground="#888888" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Name="BtnCollapse" Content="◀" Background="Transparent" BorderThickness="0" Foreground="#888888" Click="ToggleSidebar_Click" Cursor="Hand"/>
                    </Grid>

                    <!-- History List -->
                    <ListBox Grid.Row="1" Name="LstHistory" Background="#161616" BorderThickness="0" Foreground="White" SelectionChanged="LstHistory_SelectionChanged">
                        <!-- Items populated dynamically -->
                    </ListBox>

                    <!-- Sidebar Footer -->
                    <StackPanel Grid.Row="2" Spacing="8" Margin="0,10,0,0">
                        <Button Content="+ Nuevo Sonido" Name="BtnNewSound" Click="BtnNewSound_Click"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Background="#2d2d30" Foreground="White" Padding="0,7" CornerRadius="4" FontWeight="Bold" Cursor="Hand" />
                        
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="Escala" Foreground="#888888" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Slider Grid.Column="1" Name="ZoomSlider" Minimum="0.6" Maximum="1.3" Value="1.0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Name="TxtZoomVal" Text="100%" Foreground="#888888" FontSize="10.5" VerticalAlignment="Center" Margin="5,0,0,0" Width="30" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Splitter (Column 1) -->
            <GridSplitter Grid.Column="1" Background="Transparent" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"/>

            <!-- Main Control Panel (Column 2) -->
            <Grid Grid.Column="2" Name="WorkspaceGrid" RowDefinitions="60,*">
                <!-- Active Sound Header (Row 0) -->
                <Border Grid.Row="0" BorderBrush="#2d2d2d" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,0">
                        <Button Grid.Column="0" Name="BtnExpand" Content="▶" Background="Transparent" BorderThickness="0" Foreground="#888888" Click="ToggleSidebar_Click" IsVisible="False" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Name="TxtActiveSoundName" Text="Sin Sonido" FontSize="16" FontWeight="Bold" Foreground="White" />
                            <TextBlock Name="TxtActiveSoundDesc" Text="Tipo de Onda: Cuadrada | Parámetros: 24" FontSize="10.5" Foreground="#888888" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="🧪 Mutar Copia" Background="#282828" Foreground="White" Padding="12,6" CornerRadius="4" FontWeight="Bold" Click="Mutate_Click" Cursor="Hand"/>
                            <Button Content="📋 Copiar" Background="#238636" Foreground="White" Padding="12,6" CornerRadius="4" FontWeight="Bold" Click="CopyParams_Click" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Workspace Layout Content (Row 1) -->
                <Grid Grid.Row="1" Name="WorkspaceContentGrid" ColumnDefinitions="170,20,*,20,270" Margin="20">
                    <!-- Column 0: Presets Panel -->
                    <Border Grid.Column="0" Background="#1a1a1a" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8" Padding="12">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Text="PREAJUSTES RÁPIDOS" Foreground="#58a6ff" FontSize="11" FontWeight="Bold" Margin="0,0,0,10" />
                            <ScrollViewer Grid.Row="1">
                                <StackPanel Name="PresetsPanel" Spacing="6">
                                    <!-- Preset buttons added dynamically in C# -->
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Column 2: Parameters List -->
                    <Border Grid.Column="2" Background="#1a1a1a" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8" Padding="12">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <TextBlock Grid.Row="0" Text="PARÁMETROS DEL SINTETIZADOR" Foreground="#58a6ff" FontSize="11" FontWeight="Bold" Margin="0,0,0,10" />
                            
                            <!-- Wave Selector -->
                            <Grid Grid.Row="1" Name="WaveSelectorGrid" ColumnDefinitions="*,4,*,4,*,4,*,4,*" Margin="0,0,0,15">
                                <Button Grid.Column="0" Content="🔳 Cuadrada" Tag="0" Click="SetWaveType_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,6" FontSize="10.5" FontWeight="Bold"/>
                                <Button Grid.Column="2" Content="📈 Sierra" Tag="1" Click="SetWaveType_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,6" FontSize="10.5" FontWeight="Bold"/>
                                <Button Grid.Column="4" Content="〰️ Senoidal" Tag="2" Click="SetWaveType_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,6" FontSize="10.5" FontWeight="Bold"/>
                                <Button Grid.Column="6" Content="💨 Ruido" Tag="3" Click="SetWaveType_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,6" FontSize="10.5" FontWeight="Bold"/>
                                <Button Grid.Column="8" Content="🔺 Triang." Tag="4" Click="SetWaveType_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,6" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <!-- Parameters Scrollable -->
                            <ScrollViewer Grid.Row="2">
                                <StackPanel Name="SlidersPanel" Spacing="6" Margin="0,0,5,0">
                                    <!-- Sliders populated dynamically in C# -->
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Column 4: Playback & Visualizer -->
                    <Border Grid.Column="4" Background="#1a1a1a" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="VISUALIZACIÓN DE ONDA" Foreground="#58a6ff" FontSize="11" FontWeight="Bold" />
                            
                            <!-- Canvas Wave -->
                            <Border Background="#0f0f0f" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="6" Height="100" ClipToBounds="True">
                                <Canvas Name="WaveCanvas"/>
                            </Border>

                            <!-- PlayOnChange -->
                            <CheckBox Name="ChkPlayOnChange" Content="Reproducir al cambiar" IsChecked="True" Foreground="White" FontSize="11"/>

                            <!-- Play Sound Button -->
                            <Button Content="▶️ REPRODUCIR SONIDO" Name="BtnPlay" Click="PlayActiveSound_Click"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="#58a6ff" Foreground="Black" Padding="0,12" CornerRadius="4" FontWeight="Bold" FontSize="13" Cursor="Hand" />

                            <!-- Volume Slider -->
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                <Path Grid.Column="0" Data="M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.85 14,18.71V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.77 16.5,12M3,9V15H7L12,20V4L7,9H3Z"
                                      Fill="#888888" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" Name="VolumeSlider" Minimum="0.0" Maximum="1.0" Value="0.5" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Divider -->
                            <Border BorderBrush="#2d2d2d" BorderThickness="0,0,0,1" Height="1" Margin="0,4"/>

                            <TextBlock Text="ACCIONES RÁPIDAS" Foreground="#58a6ff" FontSize="11" FontWeight="Bold" />
                            
                            <Button Content="💾 Exportar archivo .WAV" Click="ExportWav_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#1e1e1f" Foreground="White" Padding="0,8" Cursor="Hand"/>
                            <Button Content="📁 Cargar parámetros" Click="LoadParams_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#1e1e1f" Foreground="White" Padding="0,8" Cursor="Hand"/>
                            <Button Content="💿 Guardar parámetros" Click="SaveParams_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#1e1e1f" Foreground="White" Padding="0,8" Cursor="Hand"/>

                            <TextBlock Name="TxtSoundInfo" Text="Muestras: 0" Foreground="#888888" FontSize="9.5" HorizontalAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
